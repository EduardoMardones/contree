{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Context Tree",
  "version": "0.1.0",
  "identifier": "com.eduardo.contexttree",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Context Tree . Generador de contexto IA",
        "width": 1380,
        "height": 820,
        "minWidth": 1000,
        "minHeight": 640
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
